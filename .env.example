# ─────────────────────────────────────────────────────────────
# Mi Gente Latino — environment variables
# Copy this file to ".env.local" and fill in your Supabase keys.
# The landing works WITHOUT these (demo mode), but to actually
# store emails for market validation you need a Supabase project.
# ─────────────────────────────────────────────────────────────

# Public Supabase URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon / publishable key (Project Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# Mini CRM (server-only — NEVER prefix these with NEXT_PUBLIC)
# ─────────────────────────────────────────────────────────────

# Service-role key (Project Settings → API → service_role). Lets the CRM
# READ the leads list. Keep secret — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# CRM login (simple username + password, no email/magic link).
CRM_USERNAME=admin
CRM_PASSWORD=

# Optional: enables the CRM "Resolve with AI" button that maps still-pending
# free-text inputs to the catalog with Claude. Without it, the rest of the
# normalization layer (deterministic + fuzzy + manual review) works fine.
ANTHROPIC_API_KEY=
